class ChimeraEvaluator:
    """Main evaluation class for Chimera-3X model"""

    def __init__(self, model_path: str = "LGAI-EXAONE/EXAONE-3.5-2.4B-Instruct"):
        print(" Initializing Chimera-3X Evaluation System...")
        print("=" * 60)

        self.model = MediExpert(model_path)
        self.dataset = MedicalEvaluationDataset()
        self.results = []

        print(f" Model loaded: {model_path}")
        print(f" Loaded {len(self.dataset.get_all_questions())} evaluation questions")
        print("=" * 60)

    def _extract_answer_from_response(self, response: str, question: EvaluationQuestion) -> str:
        """Extract the model's answer from its response"""
        response = response.strip().upper()

        if question.question_type == "multiple_choice":
            # Look for pattern like "A)", "B.", "A:", etc.
            pattern = r'\b([A-D])[.):\s]'
            match = re.search(pattern, response)
            if match:
                return match.group(1)

            # Look for standalone letters at the beginning
            if response.startswith(('A', 'B', 'C', 'D')):
                return response[0]

            # Look for "The answer is X" pattern
            answer_pattern = r'(?:ANSWER|CORRECT|CHOICE)\s+IS\s+([A-D])'
            match = re.search(answer_pattern, response)
            if match:
                return match.group(1)

        elif question.question_type == "yes_no":
            if "YES" in response:
                return "YES"
            elif "NO" in response:
                return "NO"

        elif question.question_type == "short_answer":
            # Return the first sentence as the answer
            sentences = response.split('.')
            return sentences[0].strip() if sentences else response

        return response[:100]  # Return first 100 chars if no clear answer found

    def _calculate_accuracy(self, model_answer: str, correct_answer: str, question_type: str) -> Tuple[bool, float]:
        """Calculate if the answer is correct and confidence score"""

        if question_type == "multiple_choice" or question_type == "yes_no":
            is_correct = model_answer.upper() == correct_answer.upper()
            confidence = 1.0 if is_correct else 0.0

        elif question_type == "short_answer":
            # For short answers, use fuzzy matching
            model_lower = model_answer.lower()
            correct_lower = correct_answer.lower()

            # Check if key terms from correct answer are in model answer
            correct_terms = set(correct_lower.split())
            model_terms = set(model_lower.split())

            overlap = len(correct_terms.intersection(model_terms))
            total_correct_terms = len(correct_terms)

            confidence = overlap / total_correct_terms if total_correct_terms > 0 else 0.0
            is_correct = confidence >= 0.5  # 50% term overlap threshold

        else:
            is_correct = False
            confidence = 0.0

        return is_correct, confidence

    def evaluate_single_question(self, question: EvaluationQuestion) -> EvaluationResult:
        """Evaluate the model on a single question"""

        # Format the question for the model
        if question.options:
            options_text = "\n".join([f"{k}. {v}" for k, v in question.options.items()])
            formatted_question = f"{question.question_text}\n\nOptions:\n{options_text}\n\nAnswer:"
        else:
            formatted_question = f"{question.question_text}\n\nAnswer:"

        # Get model response
        start_time = datetime.now()
        response_data = self.model.consult(formatted_question)
        end_time = datetime.now()

        response_time = (end_time - start_time).total_seconds()
        model_response = response_data.get("response", "")

        # Extract answer
        model_answer = self._extract_answer_from_response(model_response, question)

        # Calculate accuracy
        is_correct, confidence = self._calculate_accuracy(
            model_answer, question.correct_answer, question.question_type
        )

        # Create result
        result = EvaluationResult(
            question_id=question.question_id,
            question_text=question.question_text,
            model_answer=model_answer,
            correct_answer=question.correct_answer,
            is_correct=is_correct,
            confidence_score=confidence,
            response_time=response_time,
            category=question.category,
            difficulty=question.difficulty
        )

        return result

    def run_full_evaluation(self) -> Dict:
        """Run complete evaluation on all questions"""

        print(" Starting Full Medical AI Evaluation...")
        print("=" * 60)

        questions = self.dataset.get_all_questions()
        total_questions = len(questions)

        self.results = []

        for i, question in enumerate(questions, 1):
            print(f" Evaluating Question {i}/{total_questions} ({question.question_id})")
            print(f"   Category: {question.category} | Difficulty: {question.difficulty}")

            try:
                result = self.evaluate_single_question(question)
                self.results.append(result)

                status = " CORRECT" if result.is_correct else " INCORRECT"
                print(f"   {status} | Confidence: {result.confidence_score:.2f}")

            except Exception as e:
                print(f"     Error: {str(e)}")
                continue

            print("-" * 40)

        # Calculate overall metrics
        evaluation_metrics = self._calculate_evaluation_metrics()

        print("\n EVALUATION COMPLETED!")
        print("=" * 60)
        print(f" Overall Accuracy: {evaluation_metrics['overall_accuracy']:.2%}")
        print(f"  Average Response Time: {evaluation_metrics['avg_response_time']:.2f}s")
        print(f"Total Questions: {evaluation_metrics['total_questions']}")
        print(f" Correct Answers: {evaluation_metrics['correct_answers']}")
        print("=" * 60)

        return evaluation_metrics

    def _calculate_evaluation_metrics(self) -> Dict:
        """Calculate comprehensive evaluation metrics"""

        if not self.results:
            return {}

        # Overall metrics
        total_questions = len(self.results)
        correct_answers = sum(1 for r in self.results if r.is_correct)
        overall_accuracy = correct_answers / total_questions
        avg_response_time = np.mean([r.response_time for r in self.results])
        avg_confidence = np.mean([r.confidence_score for r in self.results])

        # Category-wise metrics
        categories = set(r.category for r in self.results)
        category_metrics = {}

        for category in categories:
            cat_results = [r for r in self.results if r.category == category]
            cat_correct = sum(1 for r in cat_results if r.is_correct)
            cat_total = len(cat_results)
            cat_accuracy = cat_correct / cat_total if cat_total > 0 else 0

            category_metrics[category] = {
                'accuracy': cat_accuracy,
                'correct': cat_correct,
                'total': cat_total
            }

        # Difficulty-wise metrics
        difficulties = set(r.difficulty for r in self.results)
        difficulty_metrics = {}

        for difficulty in difficulties:
            diff_results = [r for r in self.results if r.difficulty == difficulty]
            diff_correct = sum(1 for r in diff_results if r.is_correct)
            diff_total = len(diff_results)
            diff_accuracy = diff_correct / diff_total if diff_total > 0 else 0

            difficulty_metrics[difficulty] = {
                'accuracy': diff_accuracy,
                'correct': diff_correct,
                'total': diff_total
            }

        return {
            'overall_accuracy': overall_accuracy,
            'correct_answers': correct_answers,
            'total_questions': total_questions,
            'avg_response_time': avg_response_time,
            'avg_confidence': avg_confidence,
            'category_metrics': category_metrics,
            'difficulty_metrics': difficulty_metrics,
            'evaluation_timestamp': datetime.now().isoformat()
        }

    def generate_detailed_report(self) -> str:
        """Generate a detailed evaluation report"""

        if not self.results:
            return "No evaluation results available. Run evaluation first."

        metrics = self._calculate_evaluation_metrics()

        report = []
        report.append("=" * 80)
        report.append("CHIMERA-3X MEDICAL AI EVALUATION REPORT")
        report.append("=" * 80)
        report.append(f"Evaluation Date: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
        report.append(f"Model: {self.model.model_path}")
        report.append("")

        # Overall Performance
        report.append(" OVERALL PERFORMANCE")
        report.append("-" * 40)
        report.append(f"Total Questions Evaluated: {metrics['total_questions']}")
        report.append(f"Correct Answers: {metrics['correct_answers']}")
        report.append(f"Overall Accuracy: {metrics['overall_accuracy']:.2%}")
        report.append(f"Average Response Time: {metrics['avg_response_time']:.2f} seconds")
        report.append(f"Average Confidence Score: {metrics['avg_confidence']:.2f}")
        report.append("")

        # Category Performance
        report.append(" CATEGORY-WISE PERFORMANCE")
        report.append("-" * 40)
        for category, cat_metrics in metrics['category_metrics'].items():
            report.append(f"{category.title()}: {cat_metrics['accuracy']:.2%} "
                         f"({cat_metrics['correct']}/{cat_metrics['total']})")
        report.append("")

        # Difficulty Performance
        report.append("⚡ DIFFICULTY-WISE PERFORMANCE")
        report.append("-" * 40)
        for difficulty, diff_metrics in metrics['difficulty_metrics'].items():
            report.append(f"{difficulty.title()}: {diff_metrics['accuracy']:.2%} "
                         f"({diff_metrics['correct']}/{diff_metrics['total']})")
        report.append("")

        # Detailed Results
        report.append(" DETAILED QUESTION RESULTS")
        report.append("-" * 40)

        for result in self.results:
            status = " CORRECT" if result.is_correct else " INCORRECT"
            report.append(f"{result.question_id}: {status}")
            report.append(f"   Question: {result.question_text[:100]}...")
            report.append(f"   Model Answer: {result.model_answer}")
            report.append(f"   Correct Answer: {result.correct_answer}")
            report.append(f"   Confidence: {result.confidence_score:.2f}")
            report.append(f"   Category: {result.category} | Difficulty: {result.difficulty}")
            report.append("")

        report.append("=" * 80)

        return "\n".join(report)

    def save_results(self, filename: Optional[str] = None):
        """Save evaluation results to files"""

        if not filename:
            timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
            filename = f"chimera_evaluation_{timestamp}"

        # Save detailed report
        report = self.generate_detailed_report()
        with open(f"{filename}_report.txt", 'w', encoding='utf-8') as f:
            f.write(report)

        # Save results as JSON
        results_data = {
            'metrics': self._calculate_evaluation_metrics(),
            'results': [
                {
                    'question_id': r.question_id,
                    'question_text': r.question_text,
                    'model_answer': r.model_answer,
                    'correct_answer': r.correct_answer,
                    'is_correct': r.is_correct,
                    'confidence_score': r.confidence_score,
                    'response_time': r.response_time,
                    'category': r.category,
                    'difficulty': r.difficulty
                }
                for r in self.results
            ]
        }

        with open(f"{filename}_results.json", 'w', encoding='utf-8') as f:
            json.dump(results_data, f, indent=2, ensure_ascii=False)

        print(f" Results saved:")
        print(f"    Report: {filename}_report.txt")
        print(f"    Data: {filename}_results.json")



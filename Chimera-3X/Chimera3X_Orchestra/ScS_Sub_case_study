# Import the original MediExpert class
class MediExpert:
    def __init__(self, model_path="LGAI-EXAONE/EXAONE-3.5-2.4B-Instruct"):
        os.environ['HF_HUB_DISABLE_SYMLINKS_WARNING'] = '1'
        os.environ['TRUST_REMOTE_CODE'] = 'true'

        self.model_path = model_path
        self.device = self._get_device()
        self._ensure_dependencies()

        self.tokenizer = AutoTokenizer.from_pretrained(model_path, trust_remote_code=True)
        self.model = self._load_model()

        self.history = []
        self.prompt = self._build_system_prompt()
        self.generation_args = {
            "max_new_tokens": 800,
            "temperature": 0.7,
            "top_p": 0.9,
            "repetition_penalty": 1.2,
            "no_repeat_ngram_size": 3,
            "do_sample": True,
            "pad_token_id": None
        }

        if self.tokenizer.pad_token_id is None:
            self.tokenizer.pad_token = self.tokenizer.eos_token
        self.generation_args["pad_token_id"] = self.tokenizer.pad_token_id

    def _get_device(self):
        if torch.cuda.is_available():
            device_name = torch.cuda.get_device_name(0)
            print(f"Using GPU: {device_name}")
            return "cuda"
        print("Using CPU")
        return "cpu"

    def _ensure_dependencies(self):
        try:
            import accelerate
            import bitsandbytes
        except ImportError:
            print("Installing required dependencies...")
            import subprocess
            subprocess.check_call([sys.executable, "-m", "pip", "install", "accelerate", "bitsandbytes"])

    def _load_model(self):
        try:
            model = AutoModelForCausalLM.from_pretrained(
                self.model_path,
                torch_dtype=torch.float16 if self.device == "cuda" else torch.float32,
                device_map="auto" if self.device == "cuda" else None,
                trust_remote_code=True,
                low_cpu_mem_usage=True
            )

            if self.device == "cpu":
                model = model.to(self.device)

            return model

        except Exception as e:
            print(f"Failed to load model: {e}")
            raise

    def _build_system_prompt(self):
        return (
            "You are MediExpert-5.0 (Chimera-3X), an advanced medical AI assistant. "
            "Provide accurate, evidence-based medical information. "
            "For multiple choice questions, provide the letter of the correct answer followed by a brief explanation."
        )

    def consult(self, query: str) -> Dict:
        """Simplified consult method for evaluation"""
        try:
            messages = [
                {"role": "system", "content": self._build_system_prompt()},
                {"role": "user", "content": query}
            ]

            inputs = self.tokenizer.apply_chat_template(
                messages,
                tokenize=True,
                add_generation_prompt=True,
                return_tensors="pt"
            ).to(self.device)

            with torch.no_grad():
                outputs = self.model.generate(
                    inputs,
                    **self.generation_args,
                    eos_token_id=self.tokenizer.eos_token_id
                )

            response = self.tokenizer.decode(outputs[0], skip_special_tokens=True)

            if "[|assistant|]" in response:
                response = response.split("[|assistant|]")[-1].strip()
            elif "assistant" in response.lower():
                parts = response.lower().split("assistant")
                if len(parts) > 1:
                    response = response[response.lower().rfind("assistant") + 9:].strip()

            return {
                "response": response,
                "timestamp": datetime.now().isoformat()
            }

        except Exception as e:
            print(f"Error in consult: {e}")
            return {
                "response": "Error generating response",
                "timestamp": datetime.now().isoformat()
            }

@dataclass
class EvaluationQuestion:
    """Structure for evaluation questions"""
    question_id: str
    question_text: str
    options: Optional[Dict[str, str]]  # For multiple choice: {"A": "option1", "B": "option2", ...}
    correct_answer: str
    question_type: str  # "multiple_choice", "yes_no", "short_answer"
    category: str  # "anatomy", "physiology", "pathology", "pharmacology", etc.
    difficulty: str  # "easy", "medium", "hard"
    source: str  # "PubMedQA", "BioASQ", "MedQA", "Custom"

@dataclass
class EvaluationResult:
    """Structure for evaluation results"""
    question_id: str
    question_text: str
    model_answer: str
    correct_answer: str
    is_correct: bool
    confidence_score: float
    response_time: float
    category: str
    difficulty: str

